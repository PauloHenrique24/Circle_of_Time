  m_Name: Npc Irina
  m_EditorClassIdentifier: 
  nome: Irina
  dialogos:
  - dialogo: '"Time is a cycle, and I am its beat."'
    evento:
      m_PersistentCalls:
        m_Calls: []
    desbloquear: 
  - dialogo: '"You seem... different. Have we met before?"'
    evento:
      m_PersistentCalls:
        m_Calls: []
    desbloquear: 
  - dialogo: '"I rang the bell, but I swear I already did that."'
    evento:
      m_PersistentCalls:
        m_Calls: []
    desbloquear: 
  - dialogo: '"The sound of the bell... it pains my soul."'
    evento:
      m_PersistentCalls:
        m_Calls: []
    desbloquear: 
  - dialogo: '"I remember... you tried to stop this before."'
    evento:
      m_PersistentCalls:
        m_Calls: []
    desbloquear: 
  - dialogo: '"Go to the temple, Elias. Break the clock."'
    evento:
      m_PersistentCalls:
        m_Calls: []
    desbloquear: 
